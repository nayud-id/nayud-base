{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nayud.local/schema/secrets.schema.json",
  "title": "Nayud Secrets Payload Schema (decrypted plaintext)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "environment", "namespace", "clusters", "app"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Payload schema version for compatibility management",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "default": "1.0"
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "staging", "prod"],
      "description": "Intended environment of this payload"
    },
    "namespace": {
      "type": "string",
      "description": "Aerospike namespace name",
      "default": "nayud",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "description": "Non-sensitive informational metadata",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "owner": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "key_id": { "type": "string", "description": "Logical ID of decrypt key (KMS/HSM alias or Keychain item)" }
      }
    },
    "clusters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary"],
      "properties": {
        "primary": { "$ref": "#/$defs/ClusterConfig" },
        "secondary": { "$ref": "#/$defs/ClusterConfig" }
      }
    },
    "app": { "$ref": "#/$defs/AppConfig" }
  },
  "$defs": {
    "Seed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host"],
      "properties": {
        "host": {
          "type": "string",
          "description": "Seed host (DNS name preferred; may be IPv4/IPv6)",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 3000
        }
      }
    },
    "TLSConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "ca_cert_path": {
          "type": "string",
          "description": "Absolute path to CA bundle/anchor (outside repo)",
          "minLength": 1
        },
        "client_cert_path": { "type": "string", "description": "Absolute path to client certificate (optional)" },
        "client_key_path": { "type": "string", "description": "Absolute path to client private key (optional)" },
        "client_key_passphrase_keychain_item": {
          "type": "string",
          "description": "OS keychain item name or KMS ref for decrypting client key (do not store passphrase here)"
        },
        "server_name_override": { "type": "string", "description": "SNI override if different from host" },
        "min_version": { "type": "string", "enum": ["1.2", "1.3"], "default": "1.2" },
        "cipher_suites": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional explicit cipher suites"
        }
      }
    },
    "AuthConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["none", "userpass", "external"], "default": "none" },
        "username": { "type": "string" },
        "password_keychain_item": {
          "type": "string",
          "description": "OS keychain item or external secret ref containing password (never plaintext)"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "userpass" } }, "required": ["mode"] },
          "then": { "required": ["username", "password_keychain_item"] }
        }
      ]
    },
    "Timeouts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connect_ms": { "type": "integer", "minimum": 1, "maximum": 60000, "default": 500 },
        "read_ms": { "type": "integer", "minimum": 1, "maximum": 10000, "default": 15 },
        "write_ms": { "type": "integer", "minimum": 1, "maximum": 10000, "default": 15 },
        "total_ms": { "type": "integer", "minimum": 1, "maximum": 60000, "default": 10000 }
      }
    },
    "Retries": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 10, "default": 2 },
        "sleep_between_retries_ms": { "type": "integer", "minimum": 0, "maximum": 2000, "default": 10 },
        "retry_on_timeout": { "type": "boolean", "default": true }
      }
    },
    "ReadPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replica": { "type": "string", "enum": ["master", "any"], "default": "master" },
        "consistency_level": { "type": "string", "enum": ["one", "all"], "default": "one" },
        "allow_partial_results": { "type": "boolean", "default": false }
      }
    },
    "WritePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit_level": { "type": "string", "enum": ["commit_all", "commit_master"], "default": "commit_all" },
        "generation_policy": { "type": "string", "enum": ["none", "eq", "gt"], "default": "none" },
        "key_exists_action": { "type": "string", "enum": ["update", "replace", "create_only", "update_only"], "default": "update" },
        "durable_delete": { "type": "boolean", "default": false },
        "send_key": { "type": "boolean", "default": true }
      }
    },
    "BatchPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_concurrency": { "type": "integer", "minimum": 1, "maximum": 4096, "default": 64 },
        "allow_inline": { "type": "boolean", "default": true },
        "send_set_name": { "type": "boolean", "default": false },
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 10, "default": 2 },
        "sleep_between_retries_ms": { "type": "integer", "minimum": 0, "maximum": 2000, "default": 10 }
      }
    },
    "SocketPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_connections_per_node": { "type": "integer", "minimum": 1, "maximum": 100000, "default": 300 },
        "connection_idle_timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 3600000, "default": 60000 },
        "login_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 60000, "default": 5000 }
      }
    },
    "ClientPolicies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeouts", "retries", "read", "write", "batch", "socket"],
      "properties": {
        "timeouts": { "$ref": "#/$defs/Timeouts" },
        "retries": { "$ref": "#/$defs/Retries" },
        "read": { "$ref": "#/$defs/ReadPolicy" },
        "write": { "$ref": "#/$defs/WritePolicy" },
        "batch": { "$ref": "#/$defs/BatchPolicy" },
        "socket": { "$ref": "#/$defs/SocketPolicy" }
      }
    },
    "ClusterConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seeds", "tls", "auth", "policies"],
      "properties": {
        "seeds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Seed" },
          "minItems": 1,
          "description": "Seed hosts. Use >= 3 in production for resilience"
        },
        "tls": { "$ref": "#/$defs/TLSConfig" },
        "auth": { "$ref": "#/$defs/AuthConfig" },
        "policies": { "$ref": "#/$defs/ClientPolicies" },
        "rack_aware": { "type": "boolean", "default": false },
        "rack_id": { "type": "integer", "minimum": 0 },
        "cluster_name_expect": { "type": "string", "description": "Optional expected cluster name for safety" }
      }
    },
    "FeatureFlags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dual_write_mode": { "type": "string", "enum": ["require_both", "best_effort"], "default": "require_both" },
        "read_preference": { "type": "string", "enum": ["prefer_primary", "prefer_secondary", "primary_only", "secondary_only"], "default": "prefer_primary" },
        "read_failover_on_errors": {
          "type": "array",
          "description": "Error categories that trigger read failover",
          "items": { "type": "string", "enum": ["timeout", "connection", "server_busy", "unavailable"] },
          "default": ["timeout", "connection", "unavailable"]
        },
        "enable_auditor": { "type": "boolean", "default": false },
        "enable_repair_queue": { "type": "boolean", "default": true }
      }
    },
    "HAConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "health_probe_interval_ms": { "type": "integer", "minimum": 100, "maximum": 600000, "default": 2000 },
        "unhealthy_threshold": { "type": "integer", "minimum": 1, "maximum": 100, "default": 3 },
        "healthy_threshold": { "type": "integer", "minimum": 1, "maximum": 100, "default": 3 },
        "circuit_breaker_open_ms": { "type": "integer", "minimum": 1000, "maximum": 3600000, "default": 30000 },
        "failover_cooldown_ms": { "type": "integer", "minimum": 0, "maximum": 3600000, "default": 30000 },
        "dns_ttl_seconds": { "type": "integer", "minimum": 1, "maximum": 3600, "default": 30 },
        "prefer_dns_round_robin": { "type": "boolean", "default": true }
      }
    },
    "AppConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_flags", "ha"],
      "properties": {
        "feature_flags": { "$ref": "#/$defs/FeatureFlags" },
        "ha": { "$ref": "#/$defs/HAConfig" }
      }
    }
  }
}